s = input().split()

keypad = {
    '2': "ABC",
    '3': "DEF",
    '4': "GHI",
    '5': "JKL",
    '6': "MNO",
    '7': "PQRS",
    '8': "TUV",
    '9': "WXYZ",
    '0': " "
}

ans = ""

for group in s:
    count = 1
    for ch in keypad[group[0]]:
        if count == len(group):
            ans += ch
            break
        count += 1

print(ans)
