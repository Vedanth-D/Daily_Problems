s = input().split()

ans = ""

for group in s:
    if group == "0":
        ans += " "
    else:
        digit = int(group[0])
        press = len(group)

        if digit <= 6:
            ch = chr(ord('A') + (digit - 2) * 3 + press - 1)
        elif digit == 7:
            ch = chr(ord('P') + press - 1)
        elif digit == 8:
            ch = chr(ord('T') + press - 1)
        else:   # 9
            ch = chr(ord('W') + press - 1)

        ans += ch

print(ans)

