def maxDigits(number):
  number = abs(number)

  if number == 0:
    return 0

  return maxDigitsHelper(number)

def maxDigitsHelper(number):
  if number < 10:
    return number
  
  digit = number % 10
  max_val = maxDigitsHelper(number // 2)
  
  return digit if digit > max_val else max_val

number = int(input("Enter the number: "))
print(maxDigits(number))
